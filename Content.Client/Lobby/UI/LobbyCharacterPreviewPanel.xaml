<Control
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls">
    
    <BoxContainer Name="VBox" Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
        <BoxContainer Name="Loaded" Orientation="Vertical" Visible="False" HorizontalExpand="True" VerticalExpand="True">
            
            <Label Name="Summary" HorizontalAlignment="Center" Margin="0 5" StyleClasses="LabelBig" />
            
            <BoxContainer Name="ViewBox" 
                          Orientation="Horizontal" 
                          HorizontalAlignment="Center" 
                          VerticalExpand="True"
                          Margin="10">
                </BoxContainer>

            <controls:VSpacer/>
        </BoxContainer>
        
        <Label Name="Unloaded" 
               Text="{Loc 'lobby-character-preview-panel-unloaded-preferences-label'}" 
               HorizontalAlignment="Center" 
               VerticalAlignment="Center"
               VerticalExpand="True"/>
    </BoxContainer>
</Control>